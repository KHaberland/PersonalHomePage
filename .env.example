# ===========================================
# Переменные окружения для всего проекта
# Скопируйте в .env и заполните значения
# ===========================================

# ---------- Backend (Django) ----------
SECRET_KEY=your-django-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# База данных
DATABASE_URL=postgresql://user:password@localhost:5432/personal_homepage_db

# CORS (URL фронтенда)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Media storage (опционально: AWS S3 или Cloudinary)
# AWS S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-central-1
# AWS_S3_CUSTOM_DOMAIN=  # опционально
# AWS_S3_ENDPOINT_URL=   # для S3-совместимых (R2, DigitalOcean)
# Cloudinary: pip install django-cloudinary-storage, затем CLOUDINARY_URL=cloudinary://...

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Базовый URL сайта для SEO (sitemap, Open Graph, canonical). В production: https://yourdomain.com
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Hero-видео (опционально). WebM — сжатый формат для лучшей производительности
# NEXT_PUBLIC_HERO_VIDEO_URL=https://...
# NEXT_PUBLIC_HERO_VIDEO_WEBM=https://...
# NEXT_PUBLIC_HERO_VIDEO_POSTER=https://...
# Затемнение поверх hero-видео, 0–1 (после изменения — перезапуск dev-сервера)
# NEXT_PUBLIC_HERO_OVERLAY_OPACITY=0.55
